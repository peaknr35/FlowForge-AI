# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Ollama (local LLM) ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_LOCAL_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET_PROD=whsec_YOUR_PROD_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY

# Stripe Price IDs — Starter
STRIPE_STARTER_WEEKLY_PRICE_ID=price_YOUR_ID
STRIPE_STARTER_MONTHLY_PRICE_ID=price_YOUR_ID

# Stripe Price IDs — Pro
STRIPE_PRO_MONTHLY_PRICE_ID=price_YOUR_ID
STRIPE_PRO_YEARLY_PRICE_ID=price_YOUR_ID

# Stripe Price IDs — Agency
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_YOUR_ID
STRIPE_AGENCY_YEARLY_PRICE_ID=price_YOUR_ID

# Stripe Price ID — Lifetime
STRIPE_LIFETIME_PRICE_ID=price_YOUR_ID

# ─── Google OAuth ───
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-YOUR_SECRET
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000